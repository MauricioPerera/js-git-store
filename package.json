{
  "name": "js-git-store",
  "version": "1.0.1",
  "description": "Git-backed storage adapter for js-doc-store and js-vector-store — tree-first, blob-on-demand. Zero runtime deps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "STABILITY.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "npm run bench:cold-read && npm run bench:vector-load && npm run bench:persist && npm run bench:cache-eviction",
    "bench:cold-read": "tsx tests/bench/cold-read.ts",
    "bench:vector-load": "tsx tests/bench/vector-load.ts",
    "bench:persist": "tsx tests/bench/persist-throughput.ts",
    "bench:cache-eviction": "tsx tests/bench/cache-eviction.ts",
    "lint": "eslint src tests --ext .ts",
    "example:skills": "tsx examples/skills-catalog/run.ts",
    "example:vector": "tsx examples/vector-rag/run.ts",
    "e2e:github": "tsx tests/scripts/github-e2e.ts",
    "e2e:github-quick": "tsx tests/scripts/github-e2e-quick.ts",
    "soak": "tsx tests/scripts/soak.ts",
    "prepack": "npm run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "js-doc-store": "*",
    "js-vector-store": "*"
  },
  "peerDependenciesMeta": {
    "js-doc-store": { "optional": true },
    "js-vector-store": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.11.0",
    "js-doc-store": "github:MauricioPerera/js-doc-store#76333acc87fb67af8c46aa56419b165703ce32c1",
    "js-vector-store": "github:MauricioPerera/js-vector-store#2acb20ec43ec49ca1878f8998b2037d26134e013",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "git",
    "storage",
    "adapter",
    "versioned",
    "vector-store",
    "doc-store",
    "knowledge-base",
    "content-addressable",
    "rag",
    "js-doc-store",
    "js-vector-store"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MauricioPerera/js-git-store.git"
  },
  "bugs": {
    "url": "https://github.com/MauricioPerera/js-git-store/issues"
  },
  "homepage": "https://github.com/MauricioPerera/js-git-store#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
